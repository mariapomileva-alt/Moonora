{
  "name": "storybook-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"next dev\" \"node server/cover-api.cjs\"",
    "dev:web": "next dev",
    "dev:api": "node server/cover-api.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy:github": "GITHUB_ACTIONS=true npm run build && gh-pages -d out --nojekyll",
    "pages:sync": "GITHUB_ACTIONS=true npm run build && rm -rf docs && mkdir -p docs && rsync -a --delete out/ docs/"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "multer": "^2.1.1",
    "next": "16.2.6",
    "openai": "^6.37.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
